---
import type { NavigationItem } from './sidebar-item.astro'
import { getEntry } from 'astro:content'

interface Props {
	item: Extract<NavigationItem, { discriminant: 'page' }>
	class?: string
}

const { item, ...props } = Astro.props
let { slug, label } = item.value

if (!label) {
	const entry = await getEntry(slug.collection, slug.id)

	if (!entry) {
		throw new Error(`Entry not found for slug: ${slug.id}`)
	}

	label = entry.data.title
}
---

<a
	href={`/${slug.id}`}
	{...props}
	>{label}</a
>
